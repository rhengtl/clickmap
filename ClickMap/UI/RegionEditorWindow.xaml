<Window x:Class="ClickMap.UI.RegionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit region" SizeToContent="Height" Width="372"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="{StaticResource Font.Ui}" TextOptions.TextFormattingMode="Ideal">

    <Border CornerRadius="14" Background="{StaticResource B.Bg}"
            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <Grid Margin="18,14,18,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="Transparent" Margin="0,0,0,16"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock Text="Edit region" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Style="{StaticResource Btn.Icon}" HorizontalAlignment="Right" Click="Close_Click" ToolTip="Close">
                    <Path Width="11" Height="11" Stretch="Uniform" Stroke="{StaticResource B.TextMuted}"
                          StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource Geo.Close}" />
                </Button>
            </Grid>

            <!-- Fields -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Foreground="{StaticResource B.TextMuted}"
                           VerticalAlignment="Center" Margin="0,0,12,10" />
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox" Margin="0,0,0,10" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Key" Foreground="{StaticResource B.TextMuted}"
                           VerticalAlignment="Center" Margin="0,0,12,10" />
                <Button Grid.Row="1" Grid.Column="1" x:Name="KeyButton" Style="{StaticResource Btn.Subtle}"
                        Margin="0,0,0,10" Padding="10,8" HorizontalAlignment="Stretch"
                        Click="KeyButton_Click" Content="(press to set)" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Click" Foreground="{StaticResource B.TextMuted}"
                           VerticalAlignment="Center" Margin="0,0,12,10" />
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ClickTypeBox" Margin="0,0,0,10" />

                <CheckBox Grid.Row="3" Grid.Column="1" x:Name="EnabledCheck" Content="Enabled" Margin="0,4,0,4" />

                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="ConflictWarning"
                           Foreground="{StaticResource B.Orange}" TextWrapping="Wrap"
                           Visibility="Collapsed" Margin="0,10,0,0" />
            </Grid>

            <!-- Actions -->
            <Grid Grid.Row="2" Margin="0,18,0,0">
                <Button x:Name="DeleteButton" Style="{StaticResource Btn.Danger}" HorizontalAlignment="Left"
                        Content="Delete" Click="DeleteButton_Click" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource Btn.Subtle}" Margin="0,0,8,0"
                            IsCancel="True" Click="Cancel_Click" />
                    <Button Content="OK" Style="{StaticResource Btn.Primary}" IsDefault="True" Click="Ok_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>

<Window x:Class="ClickMap.UI.RegionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit region" SizeToContent="Height" Width="340"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center" Margin="0,0,10,8" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox" Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Key" VerticalAlignment="Center" Margin="0,0,10,8" />
        <Button Grid.Row="1" Grid.Column="1" x:Name="KeyButton" Margin="0,0,0,8"
                Padding="8,4" Click="KeyButton_Click" Content="(press to set)" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Click" VerticalAlignment="Center" Margin="0,0,10,8" />
        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ClickTypeBox" Margin="0,0,0,8" />

        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="EnabledCheck" Content="Enabled" Margin="0,2,0,12" />

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="DeleteButton" Content="Delete" Padding="12,4" Margin="0,0,8,0"
                    Foreground="#B00020" Click="DeleteButton_Click" />
            <Button Content="Cancel" Padding="12,4" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click" />
            <Button Content="OK" Padding="14,4" IsDefault="True" Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="ClickMap.UI.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickMap" Width="280" Height="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#2E2E2E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#444" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#F21E1E1E" BorderBrush="#3DA5FF" BorderThickness="1">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header / drag handle -->
            <Grid x:Name="HeaderBar" Grid.Row="0" Background="Transparent" Margin="0,0,0,8"
                  MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ClickMap" Foreground="White"
                           FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                <ToggleButton Grid.Column="1" x:Name="PauseToggle" Content="Pause"
                              Foreground="White" Background="#2E2E2E" Padding="8,2" Margin="0,0,6,0"
                              Click="PauseToggle_Click" />
                <Button Grid.Column="2" Content="—" Foreground="White" Background="#2E2E2E"
                        Width="26" Padding="0" Click="Hide_Click" ToolTip="Hide to tray" />
            </Grid>

            <!-- Region list -->
            <Border Grid.Row="1" Background="#141414" CornerRadius="6">
                <ListBox x:Name="RegionListBox" Background="Transparent" BorderThickness="0"
                         Foreground="White" MouseDoubleClick="RegionListBox_MouseDoubleClick"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#3DA5FF" CornerRadius="4"
                                        Padding="6,1" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Key.Display}" Foreground="Black"
                                               FontWeight="SemiBold" FontSize="12" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Add" Style="{StaticResource ToolButton}" Click="Add_Click" />
                <Button Content="Edit" Style="{StaticResource ToolButton}" Click="Edit_Click" />
                <Button Content="Delete" Style="{StaticResource ToolButton}" Click="Delete_Click" />
                <Button Content="Flash" Style="{StaticResource ToolButton}" Click="Flash_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="ClickMap.UI.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickMap" Width="312" Height="404" MinWidth="280" MinHeight="320"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual" TextOptions.TextFormattingMode="Ideal"
        FontFamily="{StaticResource Font.Ui}" KeyDown="Window_KeyDown">

    <Border CornerRadius="14" Background="{StaticResource B.Bg}"
            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.5" Color="#000000" />
        </Border.Effect>
        <Grid Margin="14,12,14,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header / drag handle -->
            <Grid x:Name="HeaderBar" Grid.Row="0" Background="Transparent"
                  MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Source="/ClickMap.png" Width="24" Height="24"
                       VerticalAlignment="Center" Margin="0,0,9,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Grid.Column="1" Text="ClickMap" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <Button Grid.Column="2" Style="{StaticResource Btn.Icon}" Click="Settings_Click" ToolTip="Settings">
                    <Path Width="17" Height="17" Stretch="Uniform" Fill="{StaticResource B.TextMuted}"
                          Data="{StaticResource Geo.Gear}" />
                </Button>
                <Button Grid.Column="3" Style="{StaticResource Btn.Icon}" Click="Hide_Click" ToolTip="Hide to tray">
                    <Rectangle Width="11" Height="2" RadiusX="1" RadiusY="1" Fill="{StaticResource B.TextMuted}" />
                </Button>
            </Grid>

            <!-- Status row -->
            <Grid Grid.Row="1" Margin="0,12,0,10">
                <ToggleButton x:Name="PauseToggle" Style="{StaticResource Toggle.Pause}"
                              HorizontalAlignment="Left" Click="PauseToggle_Click"
                              ToolTip="Pause or resume all clicking" />
                <TextBlock x:Name="CountText" Style="{StaticResource T.Caption}"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>

            <!-- Region list + empty state -->
            <Grid Grid.Row="2">
                <ListBox x:Name="RegionListBox" Style="{StaticResource ListBox.Regions}"
                         SelectionChanged="RegionListBox_SelectionChanged"
                         MouseDoubleClick="RegionListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid x:Name="Row">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{StaticResource B.Accent}" CornerRadius="6"
                                        Padding="8,3" Margin="0,0,10,0" VerticalAlignment="Center" MinWidth="34">
                                    <TextBlock Text="{Binding Key.Display}" Foreground="{StaticResource B.OnAccent}"
                                               FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ClickType}" Style="{StaticResource T.Caption}" />
                                </StackPanel>

                                <Border x:Name="OffPill" Grid.Column="2" Background="{StaticResource B.SurfaceAlt}"
                                        BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="9"
                                        Padding="7,2" VerticalAlignment="Center" Visibility="Collapsed">
                                    <TextBlock Text="Off" Style="{StaticResource T.Caption}" />
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                    <Setter TargetName="Row" Property="Opacity" Value="0.5" />
                                    <Setter TargetName="OffPill" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="20" Visibility="Collapsed">
                    <Image Source="/ClickMap.png" Width="56" Height="56" Opacity="0.5"
                           HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="No regions yet" FontWeight="SemiBold" FontSize="14"
                               HorizontalAlignment="Center" Margin="0,12,0,4" />
                    <TextBlock Style="{StaticResource T.Caption}" TextAlignment="Center" TextWrapping="Wrap"
                               Text="Add a region, drag a box on screen, then press the key to assign." />
                </StackPanel>
            </Grid>

            <!-- Actions -->
            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                <Button x:Name="AddButton" Style="{StaticResource Btn.Primary}" Click="Add_Click"
                        HorizontalAlignment="Stretch" Padding="12,9"
                        Content="＋  Add region" />
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="EditButton" Grid.Column="0" Style="{StaticResource Btn.Subtle}"
                            Margin="0,0,4,0" Click="Edit_Click" Content="Edit"
                            ToolTip="Edit the selected region (Enter / F2)" />
                    <Button x:Name="FlashButton" Grid.Column="1" Style="{StaticResource Btn.Subtle}"
                            Margin="4,0" Click="Flash_Click" Content="Flash"
                            ToolTip="Briefly highlight the selected region on screen" />
                    <Button x:Name="DeleteButton" Grid.Column="2" Style="{StaticResource Btn.Danger}"
                            Margin="4,0,0,0" Click="Delete_Click" Content="Delete"
                            ToolTip="Delete the selected region (Del)" />
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>

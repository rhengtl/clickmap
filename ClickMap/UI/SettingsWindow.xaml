<Window x:Class="ClickMap.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickMap settings" SizeToContent="Height" Width="404"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="{StaticResource Font.Ui}" TextOptions.TextFormattingMode="Ideal">

    <Border CornerRadius="14" Background="{StaticResource B.Bg}"
            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <StackPanel Margin="18,14,18,16">

            <!-- Title bar -->
            <Grid Background="Transparent" Margin="0,0,0,6" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/ClickMap.png" Width="20" Height="20" Margin="0,0,9,0"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="Settings" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <Button Style="{StaticResource Btn.Icon}" HorizontalAlignment="Right" Click="Close_Click" ToolTip="Close">
                    <Path Width="11" Height="11" Stretch="Uniform" Stroke="{StaticResource B.TextMuted}"
                          StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource Geo.Close}" />
                </Button>
            </Grid>

            <!-- Startup -->
            <TextBlock Text="STARTUP" Style="{StaticResource T.SectionHeader}" Margin="0,14,0,8" />
            <CheckBox x:Name="StartupCheck" Content="Launch ClickMap when Windows starts" />

            <!-- Clicking -->
            <TextBlock Text="CLICKING" Style="{StaticResource T.SectionHeader}" Margin="0,18,0,8" />
            <TextBlock Text="Default click type for new regions" Margin="0,0,0,5" />
            <ComboBox x:Name="ClickTypeBox" Margin="0,0,0,12" />
            <CheckBox x:Name="MoveCursorCheck" Content="Move cursor to target before clicking" />
            <TextBlock Text="When off, sends an absolute click without moving the cursor."
                       Style="{StaticResource T.Caption}" Margin="28,4,0,0" TextWrapping="Wrap" />

            <!-- Feedback -->
            <TextBlock Text="FEEDBACK" Style="{StaticResource T.SectionHeader}" Margin="0,18,0,8" />
            <CheckBox x:Name="VisualFeedbackCheck" Content="Flash the region when a click fires" Margin="0,0,0,10" />
            <CheckBox x:Name="SoundFeedbackCheck" Content="Play a sound when a click fires" />

            <!-- Panic key -->
            <TextBlock Text="PANIC KEY" Style="{StaticResource T.SectionHeader}" Margin="0,18,0,8" />
            <TextBlock Text="A global key that instantly toggles pause everywhere."
                       Style="{StaticResource T.Caption}" Margin="0,0,0,8" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PanicKeyButton" Style="{StaticResource Btn.Subtle}" Content="(none)"
                        MinWidth="150" Padding="12,8" Click="PanicKeyButton_Click" />
                <Button Content="Clear" Style="{StaticResource Btn.Subtle}" Margin="8,0,0,0"
                        Padding="12,8" Click="ClearPanic_Click" />
            </StackPanel>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="Cancel" Style="{StaticResource Btn.Subtle}" Margin="0,0,8,0"
                        IsCancel="True" Click="Cancel_Click" />
                <Button Content="OK" Style="{StaticResource Btn.Primary}" IsDefault="True" Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>

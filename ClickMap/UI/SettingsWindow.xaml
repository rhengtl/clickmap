<Window x:Class="ClickMap.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickMap settings" SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">

        <CheckBox x:Name="StartupCheck" Content="Launch ClickMap when Windows starts" Margin="0,0,0,12" />

        <TextBlock Text="Default click type for new regions" Margin="0,0,0,4" />
        <ComboBox x:Name="ClickTypeBox" Margin="0,0,0,12" />

        <CheckBox x:Name="MoveCursorCheck" Margin="0,0,0,4"
                  Content="Move cursor to target before clicking" />
        <TextBlock Text="(unchecked = absolute click without moving the cursor)"
                   Foreground="Gray" FontSize="11" Margin="20,0,0,12" />

        <CheckBox x:Name="VisualFeedbackCheck" Content="Flash the region when a click fires" Margin="0,0,0,8" />
        <CheckBox x:Name="SoundFeedbackCheck" Content="Play a sound when a click fires" Margin="0,0,0,12" />

        <TextBlock Text="Panic key (instantly toggles pause everywhere)" Margin="0,0,0,4" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="PanicKeyButton" Content="(none)" Padding="10,4" MinWidth="120"
                    Click="PanicKeyButton_Click" />
            <Button Content="Clear" Padding="10,4" Margin="8,0,0,0" Click="ClearPanic_Click" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="Cancel" Padding="12,4" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click" />
            <Button Content="OK" Padding="14,4" IsDefault="True" Click="Ok_Click" />
        </StackPanel>
    </StackPanel>
</Window>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================= -->
    <!--  ClickMap design system                                        -->
    <!--  Palette derived from the app icon: dark charcoal base, blue    -->
    <!--  chrome/cursor accent, orange region-selection accent.          -->
    <!-- ============================================================= -->

    <!-- Colors -->
    <Color x:Key="C.Bg">#181A20</Color>
    <Color x:Key="C.Surface">#22252E</Color>
    <Color x:Key="C.SurfaceAlt">#1C1F27</Color>
    <Color x:Key="C.Border">#333845</Color>
    <Color x:Key="C.Accent">#2E9BFF</Color>
    <Color x:Key="C.AccentDeep">#1E8AF0</Color>
    <Color x:Key="C.Orange">#FF8A1E</Color>
    <Color x:Key="C.Green">#2ED477</Color>
    <Color x:Key="C.Danger">#E5484D</Color>
    <Color x:Key="C.Text">#F3F4F6</Color>
    <Color x:Key="C.TextMuted">#9AA1AD</Color>
    <Color x:Key="C.TextFaint">#6B7280</Color>
    <Color x:Key="C.OnAccent">#06121F</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="B.Bg" Color="{StaticResource C.Bg}" />
    <SolidColorBrush x:Key="B.Surface" Color="{StaticResource C.Surface}" />
    <SolidColorBrush x:Key="B.SurfaceAlt" Color="{StaticResource C.SurfaceAlt}" />
    <SolidColorBrush x:Key="B.Border" Color="{StaticResource C.Border}" />
    <SolidColorBrush x:Key="B.Accent" Color="{StaticResource C.Accent}" />
    <SolidColorBrush x:Key="B.AccentDeep" Color="{StaticResource C.AccentDeep}" />
    <SolidColorBrush x:Key="B.Orange" Color="{StaticResource C.Orange}" />
    <SolidColorBrush x:Key="B.Green" Color="{StaticResource C.Green}" />
    <SolidColorBrush x:Key="B.Danger" Color="{StaticResource C.Danger}" />
    <SolidColorBrush x:Key="B.Text" Color="{StaticResource C.Text}" />
    <SolidColorBrush x:Key="B.TextMuted" Color="{StaticResource C.TextMuted}" />
    <SolidColorBrush x:Key="B.TextFaint" Color="{StaticResource C.TextFaint}" />
    <SolidColorBrush x:Key="B.OnAccent" Color="{StaticResource C.OnAccent}" />
    <SolidColorBrush x:Key="B.OrangeWash" Color="#33FF8A1E" />

    <FontFamily x:Key="Font.Ui">Segoe UI Variable Text, Segoe UI</FontFamily>

    <!-- Vector icon geometries (font-independent so they render on every Windows SKU). -->

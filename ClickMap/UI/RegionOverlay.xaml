<Window x:Class="ClickMap.UI.RegionOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False"
        Topmost="True" ResizeMode="NoResize" WindowStartupLocation="Manual"
        Background="#33000000" Cursor="Cross">
    <Canvas x:Name="RootCanvas">
        <Border x:Name="Banner" Canvas.Left="0" Canvas.Top="0"
                Background="#CC202020" CornerRadius="6" Padding="16,10" Margin="0">
            <TextBlock x:Name="InstructionText" Foreground="White" FontSize="14"
                       Text="Drag to select a region.  Esc to cancel." />
        </Border>

        <Rectangle x:Name="Selection" Visibility="Collapsed"
                   Stroke="#FF3DA5FF" StrokeThickness="2" Fill="#333DA5FF" />

        <Border x:Name="SizeTip" Visibility="Collapsed" Background="#CC000000"
                CornerRadius="3" Padding="6,2">
            <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" />
        </Border>
    </Canvas>
</Window>

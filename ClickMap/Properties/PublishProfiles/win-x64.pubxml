<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained, single-file release build: produces one ClickMap.exe that runs on a
  clean Windows machine with no .NET installed.

  Publish with:
    dotnet publish ClickMap/ClickMap.csproj -p:PublishProfile=win-x64

  Note: PublishTrimmed is intentionally false — trimming is not supported for WPF apps
  (it breaks XAML/reflection). The trade-off is a larger exe (~150 MB) in exchange for
  "just works" portability. For a small exe that needs the .NET 10 Desktop Runtime
  pre-installed, set SelfContained=false instead.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishDir>bin\publish\win-x64\</PublishDir>

    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
